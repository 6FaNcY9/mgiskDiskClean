<?php
/**
 * web/config/local.php.example
 *
 * Copy this file to web/config/local.php and fill in your local values.
 * NEVER commit web/config/local.php to version control.
 *
 * All paths are absolute or relative to DEVENV_ROOT.
 */

return [
    // ── Data directory (outside webroot) ──────────────────────────────────
    // Absolute path to the root data directory.
    // Must contain: mailboxes/<mailbox>/{maildir,reports,attachments,index.sqlite}
    // Default (dev): set to $DEVENV_ROOT/data at runtime
    'data_dir' => getenv('DEVENV_ROOT') . '/data',

    // ── Database ──────────────────────────────────────────────────────────
    // MariaDB/MySQL connection. Use socket for local dev (no TCP password needed).
    'db' => [
        'socket'   => getenv('MYSQL_UNIX_PORT') ?: (getenv('DEVENV_STATE') . '/mysql.sock'),  // local dev socket
        'host'     => '127.0.0.1',  // used if socket is empty
        'port'     => 3306,
        'dbname'   => 'mailreview',
        'user'     => 'mailreview',
        'password' => '',           // socket auth: no password needed locally
        'charset'  => 'utf8mb4',
    ],

    // ── Auth (hashed; use password_hash() to generate) ────────────────────
    // Generate: php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
    'coworker_password_hash' => '',
    'admin_password_hash'    => '',

    // ── Session ───────────────────────────────────────────────────────────
    'session' => [
        'name'     => 'mailreview_session',
        'lifetime' => 7200,  // 2 hours
    ],

    // ── App ───────────────────────────────────────────────────────────────
    'app' => [
        'debug'       => false,   // Set true only for local dev (enables error details in logs)
        'timezone'    => 'UTC',
        'items_per_page' => 50,
    ],
];
